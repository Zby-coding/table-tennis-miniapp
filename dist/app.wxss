page{--color-primary:#ff6b35;--color-primary-light:#ff8c5e;--color-primary-dark:#e0552b;--color-on-primary:#fff;--color-primary-container:#fff0e8;--color-secondary:#1a73e8;--color-secondary-light:#4d94f0;--color-secondary-dark:#1557b0;--color-secondary-container:#e8f0fe;--color-tertiary:#f59e0b;--color-tertiary-container:#fff7e0;--color-surface:#fafafa;--color-surface-container:#eee;--color-surface-container-low:#f5f5f5;--color-surface-container-lowest:#fff;--color-surface-container-high:#e8e8e8;--color-success:#0f9d58;--color-success-container:#e8f5e9;--color-warning:#f59e0b;--color-error:#d93025;--color-error-container:#fce8e6;--color-wechat-green:#07c160;--color-ball-orange:#ff6b35;--color-court-blue:#1a73e8;--color-energy-yellow:#fbbc04;--color-on-surface:#1a1a2e;--color-on-surface-variant:#5f6368;--color-on-surface-muted:#9aa0a6;--color-outline:#dadce0;--color-outline-variant:#e8eaed;--color-background:#f8f9fa;--shadow-soft:0 2rpx 6rpx rgba(0,0,0,.04);--shadow-card:0 4rpx 16rpx rgba(0,0,0,.06);--shadow-elevated:0 8rpx 32rpx rgba(0,0,0,.08);--shadow-floating:0 16rpx 64rpx rgba(0,0,0,.12);--shadow-primary:0 8rpx 24rpx rgba(255,107,53,.3);--radius-sm:16rpx;--radius-md:24rpx;--radius-lg:32rpx;--radius-xl:40rpx;--radius-2xl:48rpx;background-color:#f8f9fa;-webkit-box-sizing:border-box;box-sizing:border-box;color:#1a1a2e;font-family:-apple-system,BlinkMacSystemFont,Helvetica Neue,PingFang SC,sans-serif;font-size:28rpx;line-height:1.5;-webkit-font-smoothing:antialiased}button,image,input,scroll-view,text,view{-webkit-box-sizing:border-box;box-sizing:border-box}.gradient-primary{background:-webkit-linear-gradient(315deg,#ff6b35,#ff8c5e);background:linear-gradient(135deg,#ff6b35,#ff8c5e)}.gradient-cool{background:-webkit-linear-gradient(315deg,#1a73e8,#4d94f0);background:linear-gradient(135deg,#1a73e8,#4d94f0)}.gradient-energy{background:-webkit-linear-gradient(315deg,#ff6b35,#f59e0b);background:linear-gradient(135deg,#ff6b35,#f59e0b)}.score-number{font-variant-numeric:tabular-nums;font-weight:800}::-webkit-scrollbar{display:none;height:0;width:0}