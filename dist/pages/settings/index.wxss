.set-page{background:#f8f9fa;min-height:100vh;width:100%}.set-section-title{color:#999;font-size:24rpx;font-weight:600;padding:32rpx 32rpx 16rpx}.set-card{background:#fff;border-radius:32rpx;margin:0 32rpx 32rpx;overflow:hidden}.set-row{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;-ms-flex-pack:justify;-webkit-align-items:center;justify-content:space-between;-ms-flex-align:center;align-items:center;padding:32rpx}.set-row-left{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column}.set-row-icon{font-size:36rpx;margin-right:16rpx}.set-row-label{color:#333;font-size:30rpx;font-weight:600}.set-row-desc{color:#999;font-size:24rpx;margin-top:4rpx}.set-row-right{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;gap:8rpx}.set-arrow{color:#ccc;font-size:40rpx}.set-divider{background:#f5f5f5;height:2rpx;margin:0 32rpx}.set-logout{background:#fce8e6;border-radius:28rpx;margin:48rpx 32rpx;padding:28rpx 0;text-align:center}.set-logout:active{opacity:.8}.set-logout-text{color:#d93025;font-size:30rpx;font-weight:600}.set-version{padding:40rpx 0;text-align:center}.set-version text{color:#ccc;font-size:24rpx}