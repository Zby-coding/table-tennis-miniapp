-weight:600}.cd-tags{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-wrap:wrap;-ms-flex-wrap:wrap;flex-wrap:wrap;gap:12rpx}.cd-tag{background:#fff;border-radius:16rpx;padding:12rpx 24rpx}.cd-tag-text{color:#666;font-size:24rpx}.cd-address{color:#333;font-size:28rpx;margin-bottom:8rpx}.cd-distance{color:#888;font-size:24rpx}.cd-actions{background:#fff;border-top:2rpx solid #eee;bottom:0;-webkit-box-shadow:0 -4rpx 20rpx rgba(0,0,0,.04);box-shadow:0 -4rpx 20rpx rgba(0,0,0,.04);display:-webkit-flex;display:-ms-flexbox;display:flex;gap:20rpx;left:0;padding:24rpx 32rpx;position:fixed;right:0}.cd-btn-nav{-webkit-align-items:center;border:4rpx solid #1a73e8;border-radius:24rpx;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex:1;-ms-flex:1;flex:1;height:88rpx;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;justify-content:center}.cd-btn-nav:active{opacity:.8}.cd-btn-nav .cd-btn-text{color:#1a73e8;font-size:30rpx;font-weight:700}.cd-btn-checkin{-webkit-align-items:center;background:-webkit-linear-gradient(315deg,#ff6b35,#ff8c5e);background:linear-gradient(135deg,#ff6b35,#ff8c5e);border-radius:24rpx;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex:1.3;-ms-flex:1.3;flex:1.3;height:88rpx;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;justify-content:center}.cd-btn-checkin.done{background:#0f9d58}.cd-btn-checkin:active{opacity:.9}.cd-btn-checkin .cd-btn-text{color:#fff;font-size:30rpx;font-weight:700}