.rec-page{background:#f8f9fa;min-height:100vh;padding-bottom:80rpx;width:100%}.rec-rank-card{background:-webkit-linear-gradient(315deg,#1a73e8,#0d3b78);background:linear-gradient(135deg,#1a73e8,#0d3b78);border-radius:40rpx;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;margin:32rpx;padding:40rpx;-ms-flex-pack:justify;-webkit-align-items:center;justify-content:space-between;-ms-flex-align:center;align-items:center;overflow:hidden;position:relative}.rec-rank-bg{background:hsla(0,0%,100%,.1);border-radius:100rpx;height:200rpx;position:absolute;right:-40rpx;top:-40rpx;width:200rpx}.rec-rank-content{position:relative;z-index:1}.rec-rank-title{color:#fff;display:block;font-size:44rpx;font-weight:800}.rec-rank-sub{color:hsla(0,0%,100%,.7);font-size:24rpx;margin-top:8rpx}.rec-rank-icon{font-size:80rpx;position:relative;z-index:1}.rec-stats{display:-webkit-flex;display:-ms-flexbox;display:flex;gap:20rpx;margin:0 32rpx 32rpx}.rec-stat{background:#fff;border-radius:28rpx;-webkit-box-shadow:0 2rpx 8rpx rgba(0,0,0,.04);box-shadow:0 2rpx 8rpx rgba(0,0,0,.04);-webkit-flex:1;-ms-flex:1;flex:1;padding:32rpx;text-align:center}.rec-stat-val{display:block;font-size:44rpx;font-weight:800}.rec-stat-label{color:#999;font-size:22rpx;margin-top:8rpx}.rec-stat:nth-child(1) .rec-stat-val{color:#ff6b35}.rec-stat:nth-child(2) .rec-stat-val{color:#0f9d58}.rec-section-title{color:#333;font-size:30rpx;font-weight:700;padding:0 32rpx 20rpx}.rec-card{background:#fff;border-radius:28rpx;-webkit-box-shadow:0 2rpx 8rpx rgba(0,0,0,.04);box-shadow:0 2rpx 8rpx rgba(0,0,0,.04);display:-webkit-flex;display:-ms-flexbox;display:flex;margin:0 32rpx 20rpx;overflow:hidden}.rec-card-strip{width:8rpx}.rec-card-strip.win{background:#0f9d58}.rec-card-strip.lose{background:#d93025}.rec-card-body{-webkit-flex:1;-ms-flex:1;flex:1;padding:28rpx}.rec-card-top{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;-ms-flex-pack:justify;-webk