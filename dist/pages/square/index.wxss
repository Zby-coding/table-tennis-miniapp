.square-page{background:#f8f9fa;min-height:100vh;padding-bottom:200rpx;width:100%}.sq-search-bar{padding:24rpx 32rpx}.sq-search-input{background:#fff;border:2rpx solid #eee;border-radius:24rpx;-webkit-box-shadow:0 2rpx 8rpx rgba(0,0,0,.06);box-shadow:0 2rpx 8rpx rgba(0,0,0,.06);font-size:28rpx;height:80rpx;padding:0 28rpx;width:100%}.sq-tabs{border-bottom:2rpx solid #eee;display:-webkit-flex;display:-ms-flexbox;display:flex}.sq-tab{color:#999;-webkit-flex:1;-ms-flex:1;flex:1;font-size:30rpx;font-weight:600;padding:24rpx 0;text-align:center}.sq-tab.active{border-bottom:4rpx solid #ff6b35;color:#ff6b35}.sq-filters{padding:20rpx 32rpx;white-space:nowrap}.sq-filter-btn{background:#fff;border:2rpx solid #eee;border-radius:32rpx;display:inline-block;margin-right:16rpx;padding:12rpx 28rpx}.sq-filter-text{color:#666;font-size:24rpx}.sq-list{padding:0 32rpx}.sq-empty{color:#bbb;padding:120rpx 0;text-align:center}.sq-card{background:#fff;border-radius:32rpx;-webkit-box-shadow:0 4rpx 16rpx rgba(0,0,0,.04);box-shadow:0 4rpx 16rpx rgba(0,0,0,.04);margin-bottom:24rpx;overflow:hidden;padding:32rpx;position:relative}.sq-card-status{border-radius:0 32rpx 0 24rpx;padding:8rpx 28rpx;position:absolute;right:0;top:0}.sq-status-text{color:#fff;font-size:22rpx;font-weight:700}.sq-card-title{display:block;font-size:32rpx;font-weight:700;margin:16rpx 0 20rpx}.sq-card-meta{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-wrap:wrap;-ms-flex-wrap:wrap;flex-wrap:wrap;gap:12rpx;margin-bottom:16rpx}.sq-meta-item{color:#666;font-size:24rpx}.sq-card-desc{color:#888;font-size:26rpx;margin-bottom:24rpx}.sq-join-btn{background:-webkit-linear-gradient(315deg,#ff6b35,#ff8c5e);background:linear-gradient(135deg,#ff6b35,#ff8c5e);border-radius:20rpx;padding:20rpx 0;text-align:center}.sq-join-btn:active{opacity:.9}.sq-disabled-btn{background:#e0e0e0;border-radius:20rpx;padding:20rpx 0;text-align:center}.sq-join-text{color:#fff;font-size:28rpx;font-weight:700}.sq-disabled-btn .sq-join-text{color:#999}.sq-fab{background:-webkit-linear-gradient(315deg,#ff6b35,#f59e0b);background:linear-gradient(135deg,#ff6b35,#f59e0b);border-radius:32rpx;bottom:48rpx;-webkit-box-shadow:0 8rpx 32rpx rgba(255,107,53,.3);box-shadow:0 8rpx 32rpx rgba(255,107,53,.3);padding:28rpx 40rpx;position:fixed;right:48rpx}.sq-fab:active{-webkit-transform:scale(.95);-ms-transform:scale(.95);transform:scale(.95)}.sq-fab-text{color:#fff;font-size:30rpx;font-weight:700}