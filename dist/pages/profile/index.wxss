.profile-page{background:#f8f9fa;min-height:100vh;width:100%}.pf-card{background:-webkit-linear-gradient(315deg,#ff6b35,#e0552b);background:linear-gradient(135deg,#ff6b35,#e0552b);border-radius:0 0 48rpx 48rpx;margin:0 0 32rpx;overflow:hidden;padding:48rpx 40rpx 40rpx;position:relative}.pf-card-bg{background:hsla(0,0%,100%,.1);border-radius:120rpx;height:240rpx;position:absolute;right:-40rpx;top:-60rpx;width:240rpx}.pf-avatar-wrap{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:center;-ms-flex-pack:center;justify-content:center;margin-bottom:20rpx;position:relative;z-index:1}.pf-avatar{-webkit-align-items:center;background:hsla(0,0%,100%,.2);border:6rpx solid hsla(0,0%,100%,.4);border-radius:64rpx;display:-webkit-flex;display:-ms-flexbox;display:flex;height:128rpx;width:128rpx;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;justify-content:center}.pf-avatar-text{font-size:56rpx}.pf-name-row{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;gap:20rpx;justify-content:center;margin-bottom:32rpx;position:relative;z-index:1}.pf-name{color:#fff;font-size:40rpx;font-weight:700}.pf-level{background:hsla(0,0%,100%,.15);border-radius:20rpx;padding:8rpx 24rpx}.pf-level-text{color:#fff;font-size:22rpx;font-weight:600}.pf-stats{border-top:2rpx solid hsla(0,0%,100%,.15);display:-webkit-flex;display:-ms-flexbox;display:flex;padding-top:28rpx;position:relative;z-index:1}.pf-stat{-webkit-flex:1;-ms-flex:1;flex:1;text-align:center}.pf-stat-val{color:#fff;font-size:36rpx;font-weight:800}.pf-stat-label{color:hsla(0,0%,100%,.6);font-size:22rpx;margin-top:4rpx}.pf-section-title{color:#333;font-size:30rpx;font-weight:700;margin-bottom:20rpx;padding:0 32rpx}.pf-achs{margin-bottom:32rpx;padding:0 32rpx;white-space:nowrap}.pf-ach{-webkit-align-items:center;display:-webkit-inline-flex;display:-ms-inline-flexbox;display:inline-flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;-ms-flex-align:center;align-items:center;background:#fff;border-radius:24rpx;-webkit-box-shadow:0 2rpx 8rpx rgba(0,0,0,.04);box-shadow:0 2rpx 8rpx rgba(0,0,0,.04);margin-right:20rpx;padding:20rpx 0;width:144rpx}.pf-ach.locked{-webkit-filter:grayscale(1);filter:grayscale(1);opacity:.4}.pf-ach-icon{font-size:48rpx}.pf-ach-name{color:#666;display:block;font-size:20rpx;font-weight:600;margin-top:8rpx;overflow:hidden;text-align:center;text-overflow:ellipsis;white-space:nowrap;width:100%}.pf-menu{background:#fff;border-radius:32rpx;margin:0 32rpx 40rpx;overflow:hidden}.pf-menu-item{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;border-bottom:2rpx solid #f5f5f5;gap:24rpx;padding:32rpx}.pf-menu-item:active{background:#f9f9f9}.pf-menu-icon{font-size:36rpx}.pf-menu-label{color:#333;-webkit-flex:1;-ms-flex:1;flex:1;font-size:30rpx;font-weight:500}.pf-menu-arrow{color:#ccc;font-size:36rpx}