NODE_ENV=development
DB_HOST=
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=table_tennis
# 生产环境必须设置强随机 JWT_SECRET，禁止使用示例弱密钥
JWT_SECRET=change-me-to-a-strong-random-secret
JWT_EXPIRES_IN=7d
REDIS_HOST=
REDIS_PORT=6379
WECHAT_APP_ID=
WECHAT_APP_SECRET=
# 仅本地开发可开启；生产环境若为 true 将拒绝启动
ENABLE_DEV_AUTH=false
# 可选：开发态管理员登录码（需同时 ENABLE_DEV_AUTH=true）。未设置时不会自动提权
# DEV_ADMIN_CODE=
CORS_ORIGIN=http://localhost:5174,http://127.0.0.1:5174
PORT=3017
# 真机预览图片/静态资源基址，须为本机局域网 IP，禁止写 127.0.0.1
API_PUBLIC_URL=http://192.168.0.102:3017
